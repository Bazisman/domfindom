FINANCE_APP_DB_NAME=finance.db
FINANCE_APP_AUTH_DB_NAME=auth.db
FINANCE_APP_USERS_DATA_DIR=data/users
FINANCE_APP_ENV=production
FINANCE_APP_BACKEND_HOST=0.0.0.0
FINANCE_APP_BACKEND_PORT=8000
FINANCE_APP_BACKEND_RELOAD=false
FINANCE_APP_CORS_ORIGINS=https://your-domain.example,https://www.your-domain.example
FINANCE_APP_SESSION_COOKIE_NAME=finance_session
FINANCE_APP_SESSION_TTL_HOURS=720
FINANCE_APP_SESSION_SECRET=change-me
FINANCE_APP_SESSION_COOKIE_SECURE=true
FINANCE_APP_LOGIN_RATE_LIMIT_ATTEMPTS=10
FINANCE_APP_LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
FINANCE_APP_EXPOSE_RESET_TOKEN_IN_RESPONSE=false
FINANCE_APP_SMTP_HOST=
FINANCE_APP_SMTP_PORT=587
FINANCE_APP_SMTP_USER=
FINANCE_APP_SMTP_PASSWORD=
FINANCE_APP_SMTP_FROM=
FINANCE_APP_SMTP_USE_TLS=true
FINANCE_APP_SMTP_USE_SSL=false
FINANCE_APP_PASSWORD_RESET_URL_TEMPLATE=https://your-domain.example/login?reset_token={token}
FINANCE_APP_PASSWORD_RESET_EMAIL_SUBJECT=Password reset request
